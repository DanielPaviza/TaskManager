{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:allow-ask",
    "core:window:allow-close",
    "core:window:allow-destroy",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        {
          "url": "*"
        }
      ]
    },
    "fs:allow-mkdir",
    "fs:allow-copy-file",
    "fs:allow-exists",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-remove",
    {
      "identifier": "fs:scope",
      "allow": [
        {
          "path": "$APPDATA/**"
        }
      ]
    },
    "fs:default"
  ]
}